        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "\n",
        "print(\"TASK 1: DATA ACQUISITION, PREPROCESSING, AND EXPLORATION\")\n",
        "\n",
        "\n",
        "# 1.1 LOADING THE DATA\n",
        "# We load the bike sharing dataset using pandas for easier data manipulation.\n",
        "# The dataset contains daily bike rental counts along with weather and\n",
        "# seasonal information that we'll use to build our regression model.\n",
        "\n",
        "data = pd.read_csv('day.csv')\n",
        "\n",
        "print(\"\\n Dataset Structure:\")\n",
        "print(f\"Dataset shape: {data.shape[0]} rows, {data.shape[1]} columns\")\n",
        "print(f\"\\nColumn names:\\n{data.columns.tolist()}\")\n",
        "\n",
        "print(\"\\nData Types:\")\n",
        "print(data.dtypes)\n",
        "\n",
        "print(\"\\nFirst 5 Rows:\")\n",
        "print(data.head())\n",
        "\n",
        "print(\"\\nStatistical Summary:\")\n",
        "print(data.describe())\n",
        "\n",
        "print(\"\\nMissing Values Check:\")\n",
        "missing_values = data.isnull().sum()\n",
        "print(missing_values)\n",
        "print(f\"\\nTotal missing values: {missing_values.sum()}\")"
      ],
      "metadata": {
        "collapsed": true,
