    {
      "cell_type": "code",
      "source": [
        "#  We want to implement linear regression from scratch using the closed-form solution (the mathematical formula), not iterative methods like gradient descent.\n",
        "#  We must use NumPy/SciPy only - no scikit-learn or any other ML library like Pytorch or Tensorflow\n",
        "\n",
        "# 2.1 Model Implementation\n",
        "# The task is to implement linear regression from scratch using the closed-form solution rather than iterative methods like gradient descent, and to do so using\n",
        "# only NumPy or SciPy (no scikit-learn). The closed-form formula computes the optimal weight vector w as w = (X ^ t  X )^ -1 * X^t y.\n",
        "# X is the feature matrix (with an added column of ones for the bias term) and y is the target vector.\n",
        "\n",
        "# For numerical stability, instead of explicitly computing the matrix inverse, we use np.linalg.solve to solve the linear system (X ^ t  X )w * X^t y\n",
        "# The implementation involves adding the bias column, computing X^t X and X^t y, and encapsulating this logic in a LinearRegression class with\n",
        "# fit() (to compute weights) and predict() (to generate predictions) methods, yielding the optimal solution in a single computation.\n",
        "# This gives us the optimal weights in one calculation (no training iterations needed).\n",
        "\n",
        "# We now implement linear regression from scratch using the closed-form solution.\n",
        "# This approach directly solves for optimal weights mathematically rather than\n",
        "# using iterative optimization methods like gradient descent.\n",
        "\n",
        "\n",
        "# Linear Regression using the closed-form analytical solution.\n",
        "# This class implements the normal equation: w = (X^T X)^(-1) X^T y\n",
        "# but uses np.linalg.solve for better numerical stability.\n",
        "class LinearRegression:\n",
        "\n",
        "    def __init__(self):\n",
        "        self.weights = None\n",
        "        self.bias = None\n",
        "\n",
        "# Train the linear regression model using the closed-form solution.\n",
        "# The closed-form solution directly computes optimal weights by solving\n",
        "# the normal equation. This is faster than gradient descent for small to\n",
        "# medium datasets and guarantees finding the global optimum in one step.\n",
        "\n",
        "    def fit(self, X, y):\n",
        "\n",
        "        # Step 1: Add bias term to feature matrix\n",
        "        # We add a column of ones to X to account for the intercept (bias) term.\n",
        "        # This allows our model to learn: y = w1*x1 + w2*x2 + ... + bias\n",
        "        # Without this, the line/plane would be forced to pass through the origin.\n",
        "\n",
        "        # Convert y to float to avoid type issues with np.linalg.solve\n",
        "        # The target values must be float64 for proper matrix operations.\n",
        "\n",
        "        y = y.astype(np.float64)\n",
        "\n",
        "        n_samples = X.shape[0]\n",
        "        X_with_bias = np.column_stack([np.ones(n_samples), X])\n",
        "\n",
        "        print(f\"\\nTraining linear regression model...\")\n",
        "        print(f\"  Input features shape: {X.shape}\")\n",
        "        print(f\"  With bias term: {X_with_bias.shape}\")\n",
        "        print(f\"  Target shape: {y.shape}\")\n",
        "\n",
        "        # Step 2: Compute the closed-form solution\n",
        "        # The normal equation is: w = (X^T X)^(-1) X^T y\n",
        "        # Instead of computing the inverse explicitly (which can be numerically unstable),\n",
        "        # we use np.linalg.solve(A, b) which solves the system Aw = b more efficiently.\n",
        "        # This is mathematically equivalent but avoids numerical precision issues.\n",
        "\n",
        "        X_transpose = X_with_bias.T\n",
        "        XTX = X_transpose @ X_with_bias  # X^T X\n",
        "        XTy = X_transpose @ y             # X^T y\n",
        "\n",
        "        # Solve the system (X^T X)w = X^T y for w\n",
        "        # This gives us the optimal weights that minimize the mean squared error.\n",
        "        self.weights = np.linalg.solve(XTX, XTy)\n",
        "\n",
        "        print(f\"  Model trained successfully!\")\n",
        "        print(f\"  Learned {len(self.weights)} parameters (including bias)\")\n",
        "\n",
        "        return self\n",
        "\n",
        "\n",
        "# Make predictions using the learned weights.\n",
        "# For new data, we compute predictions as: y_pred = X * w\n",
        "# This is a simple matrix multiplication that applies our learned\n",
        "# linear relationship to new inputs.\n",
        "\n",
        "    def predict(self, X):\n",
        "        # We must add the bias column to match the training format.\n",
        "        # The first weight is the bias, and the rest are feature weights.\n",
        "        n_samples = X.shape[0]\n",
        "        X_with_bias = np.column_stack([np.ones(n_samples), X])\n",
        "\n",
        "        # Matrix multiplication: each prediction is the dot product of\n",
        "        # the feature vector with the weight vector.\n",
        "        predictions = X_with_bias @ self.weights\n",
        "\n",
        "        return predictions\n",
        "\n",
        "\n",
        "# Step 3: Train the model on our preprocessed data\n",
        "# We use the standardized features (X_final) and target (y_final) from Task 1.\n",
        "# X_final has 29 features after one-hot encoding and standardization.\n",
        "\n",
        "\n",
        "# We have to ensure both X and y are float64 for numerical stability.\n",
        "X_final = X_final.astype(np.float64)\n",
        "y_final = y_final.astype(np.float64)\n",
        "\n",
        "model = LinearRegression()\n",
        "model.fit(X_final, y_final)\n",
        "\n",
        "# Step 4: Make predictions on the training data\n",
        "# We compute predictions to evaluate how well the model fits the training data.\n",
        "# This will be used to calculate performance metrics like MSE.\n",
        "\n",
        "y_pred_train = model.predict(X_final)\n",
        "\n",
        "print(f\"\\nPredictions computed:\")\n",
        "print(f\"  First 10 actual values: {y_final[:10]}\")\n",
        "print(f\"  First 10 predictions: {y_pred_train[:10]}\")\n",
        "print(f\"  Prediction range: [{y_pred_train.min():.2f}, {y_pred_train.max():.2f}]\")\n",
        "\n"
      ],
