      "cell_type": "code",
      "source": [
        "# 2.3 EVALUATION METRIC - using RMSE\n",
        "# We implement Mean Squared Error (MSE) from scratch to evaluate model performance.\n",
        "# MSE measures average squared difference between predictions and actual values.\n",
        "# Lower MSE indicates better fit.\n",
        "\n",
        "print(\"2.3 EVALUATION METRIC - MEAN SQUARED ERROR\")\n",
        "\n",
        "\n",
        "# MSE measures the average squared difference between actual and predicted values.\n",
        "def calculate_mse(y_true, y_pred):\n",
        "\n",
        "    # Compute squared differences for each prediction\n",
        "    # We square the errors to penalize larger mistakes more and ensure all errors are positive.\n",
        "    squared_errors = (y_true - y_pred) ** 2\n",
        "\n",
        "    # Take the mean of all squared errors\n",
        "    # This gives us a single number representing overall prediction accuracy.\n",
        "    mse = np.mean(squared_errors)\n",
        "\n",
        "    return mse\n",
        "\n",
        "# ---> Calculate MSE on training set\n",
