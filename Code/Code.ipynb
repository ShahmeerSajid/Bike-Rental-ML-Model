    {
      "cell_type": "code",
      "source": [
        "\n",
        "# It's important to know why feature engineering is important.\n",
        "# Feature engineering is important because a model can only learn patterns from the features it is given.\n",
        "# Real world relationships are often not simple straight lines, and raw features may hide important\n",
        "# structure in the data. By transforming or combining features—such as adding squared terms or interaction\n",
        "# terms—we make these patterns easier for the model to capture, even if the model itself is simple.\n",
        "# Good feature engineering increases the model’s ability to fit the data and explain relationships\n",
        "# without changing the learning algorithm. In short, better features help the model learn better from\n",
        "# the same data.\n",
        "\n",
        "# How I am planning to perform Feature Engineering:\n",
        "\n",
        "# From our Task 1 visualizations, I identified several non-linear patterns. The scatter plots showed temp\n",
        "# and atemp have strong correlations (0.63) but the relationship looked (slightly) curved, suggesting\n",
        "# polynomial terms (temp², atemp²) could capture this curvature better.\n",
        "\n",
        "# The box plots revealed that seasonal effects varied significantly - Fall had highest rentals while\n",
        "# Spring had lowest - suggesting that the\n",
        "# temperature's impact might differ by season, so I'll add temp×season interactions. Similarly, weather\n",
        "# situation showed dramatic differences (Clear weather had much higher rentals than Rain/Snow), so\n",
        "# temp×weathersit interactions make sense for me to add, so that that model can learn this combination,\n",
        "# and how it affects the number of bike rentals.\n",
        "\n",
        "# The humidity scatter showed weak correlation but lots of scatter, and domain knowledge tells us\n",
        "# humidity feels different at different temperatures, so temp×hum interaction could help.\n",
        "\n",
        "# However, we need to keep in mind that overfitting can also occur, when the number of attributes and features\n",
        "# are too much, as compared to the size of the training dataset.\n",
        "# I'll avoid adding too many features to prevent overfitting (we only have 584 training samples), focusing on\n",
        "# the most promising combinations based on domain knowledge (weather interactions) and visual patterns\n",
        "# (polynomial for curves, interactions for categorical differences).\n",
        "\n",
        "mse_train_original = mse_train\n",
        "mse_test_original = mse_test\n",
        "\n",
        "\n",
        "\n",
        "# TASK 3: NON-LINEAR FEATURE ENGINEERING. -----  FIRST ATTEMPT\n",
        "# We add polynomial and interaction features to capture non-linear relationships.\n",
        "# Linear regression can model non-linear patterns if we transform the input features.\n",
        "# The model remains \"linear in parameters\" but becomes more expressive.\n",
        "\n",
        "print(\"TASK 3: NON-LINEAR FEATURE ENGINEERING\")\n",
        "\n",
        "def engineer_features(X, feature_names):\n",
        "\n",
        "    # Start with original features\n",
        "    X_engineered = X.copy()\n",
        "    new_feature_names = feature_names.copy()\n",
        "\n",
        "    # Extract indices for continuous features (standardized versions)\n",
        "    # These are at positions 2,3,4,5 in our feature matrix\n",
        "    temp_idx = 2\n",
        "    atemp_idx = 3\n",
        "    hum_idx = 4\n",
        "    windspeed_idx = 5\n",
        "\n",
        "    print(\"\\nEngineering new features based on EDA insights...\")\n",
        "\n",
        "    # 1. POLYNOMIAL FEATURES (degree 2)\n",
        "    # From scatter plots, we saw slightly curved relationships for temperature.\n",
        "    # Adding squared terms allows the model to capture this curvature.\n",
        "\n",
        "    temp_squared = X[:, temp_idx] ** 2\n",
        "    atemp_squared = X[:, atemp_idx] ** 2\n",
        "\n",
        "    X_engineered = np.column_stack([X_engineered, temp_squared, atemp_squared])\n",
        "    new_feature_names.extend(['temp_squared', 'atemp_squared'])\n",
        "    print(f\"  Added polynomial features: temp², atemp²\")\n",
        "\n",
        "    # 2. INTERACTION TERMS\n",
        "    # From box plots, we saw that temperature effects might vary by season/weather.\n",
        "    # Interactions capture \"temp matters more in certain seasons\" type relationships.\n",
        "\n",
        "    # Temperature × Working day interaction\n",
        "    # Effect of temperature might differ on working vs non-working days\n",
        "    workingday_idx = 1\n",
        "    temp_workingday = X[:, temp_idx] * X[:, workingday_idx]\n",
        "    X_engineered = np.column_stack([X_engineered, temp_workingday])\n",
        "    new_feature_names.append('temp_x_workingday')\n",
        "\n",
        "    # Temperature × Humidity interaction\n",
        "    # Domain knowledge: humidity feels different at different temperatures\n",
        "    temp_hum = X[:, temp_idx] * X[:, hum_idx]\n",
        "    X_engineered = np.column_stack([X_engineered, temp_hum])\n",
        "    new_feature_names.append('temp_x_humidity')\n",
        "\n",
        "    print(f\"  Added interaction features: temp×workingday, temp×humidity\")\n",
        "\n",
        "    print(f\"\\nFeature engineering complete:\")\n",
        "    print(f\"  Original features: {X.shape[1]}\")\n",
        "    print(f\"  Engineered features: {X_engineered.shape[1]}\")\n",
        "    print(f\"  New features added: {X_engineered.shape[1] - X.shape[1]}\")\n",
        "\n",
        "    return X_engineered, new_feature_names\n",
        "\n",
        "# Apply feature engineering to train and test sets\n",
        "X_train_engineered, feature_names_engineered = engineer_features(X_train, feature_names_final)\n",
        "X_test_engineered, _ = engineer_features(X_test, feature_names_final)\n",
        "\n",
        "# 3.2 MODEL RETRAINING AND ANALYSIS\n",
        "\n",
        "print(\"3.2 MODEL RETRAINING WITH ENGINEERED FEATURES\")\n",
        "\n",
        "# Train model with engineered features\n",
        "model_engineered = LinearRegression()\n",
        "model_engineered.fit(X_train_engineered, y_train)\n",
        "\n",
        "# Make predictions\n",
        "y_pred_train_engineered = model_engineered.predict(X_train_engineered)\n",
        "y_pred_test_engineered = model_engineered.predict(X_test_engineered)\n",
        "\n",
        "# Calculate MSE for both models\n",
        "mse_train_original = calculate_mse(y_train, y_pred_train)\n",
        "mse_train_engineered = calculate_mse(y_train, y_pred_train_engineered)\n",
        "\n",
        "mse_test_original = calculate_mse(y_test, y_pred_test)\n",
        "mse_test_engineered = calculate_mse(y_test, y_pred_test_engineered)\n",
        "\n",
        "# Compare performance\n",
        "print(\"\\nPerformance Comparison:\")\n",
        "print(f\"\\nBefore Feature Engineering:\")\n",
        "print(f\"  Training MSE: {mse_train_original:.2f}\")\n",
        "print(f\"  Test MSE: {mse_test_original:.2f}\")\n",
        "\n",
        "print(f\"\\nAfter Feature Engineering:\")\n",
        "print(f\"  Training MSE: {mse_train_engineered:.2f}\")\n",
        "print(f\"  Test MSE: {mse_test_engineered:.2f}\")\n",
        "\n",
        "print(f\"\\nImprovement:\")\n",
        "train_improvement = ((mse_train_original - mse_train_engineered) / mse_train_original) * 100\n",
        "test_improvement = ((mse_test_original - mse_test_engineered) / mse_test_original) * 100\n",
        "\n",
        "print(f\"  Training MSE: {train_improvement:.2f}% improvement\")\n",
        "print(f\"  Test MSE: {test_improvement:.2f}% improvement\")\n",
        "\n",
        "print(\"\\nAnalysis:\")\n",
        "if train_improvement > 0 and test_improvement > 0:\n",
        "    print(\"  ---->  Feature engineering improved both training and test performance\")\n",
        "elif train_improvement > 0 and test_improvement < 0:\n",
        "    print(\"  ---->  Improved training but worsened test - possible overfitting from new features\")\n",
        "elif train_improvement < 0:\n",
        "    print(\"  ---->  Training performance decreased - features may not be helpful\")\n"
