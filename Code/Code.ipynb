      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# 1.2 DATA CLEANING AND PREPROCESSING\n",
        "\n",
        "\n",
        "print(\"DATA CLEANING AND PREPROCESSING\")\n",
        "\n",
        "# Step 1: Verify Data Leakage\n",
        "# After going over the csv file, we observed that the features 'casual' and 'registered' represent counts of casual and\n",
        "# registered users respectively. Their sum equals 'cnt' (our target variable).\n",
        "\n",
        "# This implies that using these features would give the model perfect information about the target,\n",
        "# which is cheating (data leakage). We verify this before dropping them.\n",
        "\n",
        "print(\"\\nChecking for Data Leakage: \")\n",
        "leakage_check = (data['casual'] + data['registered'] == data['cnt']).all()\n",
        "print(f\"casual + registered = cnt ? {leakage_check}\")\n",
        "print(\"Result: These features MUST be dropped to avoid data leakage!\")"
      ],
      "metadata": {
        "id": "-Qcfa2aABxxq"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Step 2: Drop Irrelevant and Leakage Features\n",
        "\n",
        "# 'instant': Just a row index (1, 2, 3, ...), provides no predictive value\n",
        "# 'dteday': Specific dates would cause overfitting and aren't available at prediction time.\n",
        "# 'casual' and 'registered': Cause data leakage as explained above\n",
        "# After dropping these, we separate our features (X) from target (y).\n",
        "\n",
        "print(\"\\nDropping Features:\")\n",
        "features_to_drop = ['instant', 'dteday', 'casual', 'registered']\n",
        "print(f\"Dropping: {features_to_drop}\")\n",
        "\n",
        "data_cleaned = data.drop(columns=features_to_drop)\n",
        "\n",
        "target = data_cleaned['cnt'].values\n",
        "features = data_cleaned.drop(columns=['cnt'])\n",
        "\n",
        "print(f\"\\nAfter cleaning:\")\n",
        "print(f\"  Features shape: {features.shape}\")\n",
        "print(f\"  Target shape: {target.shape}\")\n",
        "print(f\"  Remaining features: {features.columns.tolist()}\")"
      ],
      "metadata": {
        "id": "6KnpPjTqINLL"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Step 3: Identify Feature Types\n",
        "# We categorize features into three groups:\n",
        "# 1) Categorical: Features representing categories with no natural ordering\n",
        "#    (e.g., season 1 is not \"less than\" season 2). These need one-hot encoding.\n",
        "\n",
        "# 2) Binary: Features already encoded as 0/1, no transformation needed\n",
        "# 3) Continuous: Numeric features already normalized to [0,1] range\n",
        "\n",
        "print(\"\\nFeature Categorization:\")\n",
        "\n",
        "categorical_features = ['season', 'yr', 'mnth', 'weekday', 'weathersit']\n",
        "binary_features = ['holiday', 'workingday']\n",
        "continuous_features = ['temp', 'atemp', 'hum', 'windspeed']\n",
        "\n",
        "print(f\"Categorical features (need one-hot encoding): {categorical_features}\")\n",
        "print(f\"Binary features (keep as-is): {binary_features}\")\n",
        "print(f\"Continuous features (already normalized): {continuous_features}\")"
      ],
      "metadata": {
        "id": "i5jAcfrEIbJ2"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# One-hot encoding is used to convert categorical features into a numerical format that machine learning models can interpret correctly.\n",
        "# Instead of representing categories with integers, which may incorrectly imply an ordering, each category is converted into a separate binary (0/1)\n",
        "# feature indicating its presence. The pd.get_dummies function applies this transformation to the specified categorical columns, replacing each with\n",
        "# multiple binary columns. The drop_first=True option removes one category per feature to avoid redundancy and multicollinearity, with the dropped\n",
        "# category implicitly represented when all remaining columns are zero. The print statements show the number of features before and after encoding and\n",
        "# list the new feature names, making it clear how the feature space expands as a result of this transformation.\n",
        "\n",
        "# The problem is that Model thinks 3 > 2 > 1 (treats it as a number), but seasons aren't ordered quantities. Through one-hot encoding method, each category\n",
        "# becomes independent.\n",
        "# The model learns separate effects for each season instead of treating them as ordered numbers.\n",
        "\n",
        "print(f\"Before encoding: {features.shape[1]} features\")\n",
        "\n",
        "features_encoded = pd.get_dummies(features, columns=categorical_features, drop_first=True)\n",
        "\n",
        "print(f\"After encoding: {features_encoded.shape[1]} features\")\n",
        "print(f\"\\nNew feature names:\\n{features_encoded.columns.tolist()}\")"
      ],
      "metadata": {
        "id": "7WD3cBJAJdki"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Step 5: Convert to NumPy Arrays\n",
        "# Convert the processed pandas DataFrames to numpy arrays for easier\n",
        "# mathematical operations in our linear regression implementation.\n",
        "# We also store feature names for later reference in our analysis.\n",
        "\n",
        "X_final = features_encoded.values\n",
        "y_final = target\n",
        "feature_names_final = features_encoded.columns.tolist()"
      ],
      "metadata": {
        "id": "E0VyT_dBOHCC"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# This step standardizes only the continuous features (temp, atemp, hum, and windspeed) by transforming them to have mean 0 and standard deviation 1.\n",
        "# Although these variables are already normalized to the range [0,1], they have different underlying distributions, means, and variances.\n",
        "# Standardization places them on a common statistical scale, allowing model coefficients to be interpreted as the effect of a one–standard-deviation change,\n",
        "# and enabling fair comparison across features (e.g., comparing the effect of temperature versus windspeed). Binary features such as holiday, workingday,\n",
        "# and all one-hot encoded variables are deliberately left unchanged, since standardizing binary values would turn clear 0/1 indicators into unintuitive\n",
        "# decimal values, remove their meaningful presence/absence interpretation, and offer no modeling benefit. This selective approach improves interpretability\n",
        "# and numerical stability while preserving the semantic meaning of categorical features.\n",
        "\n",
        "# We standardize temp, atemp, hum, and windspeed to put them on equal footing for coefficient comparison. Even though they're already normalized to [0,1],\n",
        "# they have different means (temp≈0.50, hum≈0.63) and spreads (temp std≈0.18, windspeed std≈0.08). After standardization (mean=0, std=1), we can directly\n",
        "# compare their coefficients: \"a 1-std increase in temp has X effect vs a 1-std increase in humidity has Y effect.\" We don't standardize binary/one-hot features\n",
        "# because they represent presence/absence (0 or 1), and converting them to decimals like -0.87 or 1.23 would lose their clear categorical interpretation.\n",
        "# This selective standardization improves numerical stability and makes our model coefficients more interpretable while preserving the meaningful binary nature of\n",
        "# categorical features.\n",
        "\n",
        "import math\n",
        "\n",
        "print(\"\\n Standardizing Continuous Features: \")\n",
        "\n",
        "continuous_feature_indices = [2, 3, 4, 5]  # temp, atemp, hum, windspeed positions. --> I verified by running the code block above.\n",
        "continuous_feature_names = ['temp', 'atemp', 'hum', 'windspeed']\n",
        "\n",
        "print(f\"Continuous features to standardize: {continuous_feature_names}\")\n",
        "print(f\"Feature indices: {continuous_feature_indices}\")\n",
        "\n",
        "# We will calculate mean and standard deviation for continuous features.\n",
        "means_continuous = np.mean(X_final[:, continuous_feature_indices], axis=0)\n",
        "\n",
        "# Manual standard deviation using power operator (avoids np.sqrt bug).\n",
        "variance_continuous = np.mean((X_final[:, continuous_feature_indices] - means_continuous)**2, axis=0)\n",
        "stds_continuous = variance_continuous ** 0.5\n",
        "\n",
        "print(f\"\\nOriginal statistics:\")\n",
        "for i, name in enumerate(continuous_feature_names):\n",
        "    print(f\"  {name}: mean={means_continuous[i]:.4f}, std={stds_continuous[i]:.4f}\")\n",
        "\n",
        "# --> standardization: (x - mean) / std\n",
        "X_standardized = X_final.copy()\n",
        "X_standardized[:, continuous_feature_indices] = ( X_final[:, continuous_feature_indices] - means_continuous) / stds_continuous\n",
        "\n",
        "\n",
        "means_after = np.mean(X_standardized[:, continuous_feature_indices], axis=0)\n",
        "\n",
        "print(f\"\\nAfter standardization:\")\n",
        "variance_after = np.mean((X_standardized[:, continuous_feature_indices] - means_after)**2, axis=0)\n",
        "stds_after = variance_after ** 0.5\n",
        "for i, name in enumerate(continuous_feature_names):\n",
        "    print(f\"  {name}: mean={means_after[i]:.4f}, std={stds_after[i]:.4f}\")\n",
        "\n",
        "X_final = X_standardized\n",
        "\n",
        "print(\"\\nStandardization Complete!!\")\n",
        "print(f\"Final feature matrix shape: {X_final.shape}\")\n",
        "print(\"Binary and one-hot encoded features remain unchanged (0 or 1)\")\n",
        "print(\"Continuous features now have mean≈0 and std≈1\")"
      ],
      "metadata": {
        "id": "oVu3yMauNahn"
